{
  "name": "@rag-indexing/core",
  "version": "1.0.0",
  "description": "Core RAG indexing functionality with semantic chunking, embeddings, and vector storage",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist"
  },
  "keywords": [
    "rag",
    "semantic-chunking",
    "embeddings",
    "vector-storage",
    "pinecone",
    "huggingface",
    "typescript"
  ],
  "author": "RAG Indexing Team",
  "license": "MIT",
  "dependencies": {
    "@huggingface/inference": "^2.6.4",
    "@huggingface/transformers": "^3.8.1",
    "@pinecone-database/pinecone": "^1.1.2",
    "node-fetch": "^3.3.2",
    "tslog": "^4.10.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/rag-indexing.git",
    "directory": "packages/rag-indexing-core"
  },
  "bugs": {
    "url": "https://github.com/your-org/rag-indexing/issues"
  },
  "homepage": "https://github.com/your-org/rag-indexing#readme",
  "packageManager": "pnpm@10.33.0"
}
